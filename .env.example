# GEMINI_API_KEY: Clé API pour les fonctionnalités IA de Gemini.
# AI Studio l'injecte automatiquement au moment de l'exécution à partir de vos secrets.
GEMINI_API_KEY=""

# SUPABASE CONFIGURATION:
# Vous pouvez configurer les deux variables ci-dessous pour l'application.
# (Notre backend Express est compatible avec les variables standards et celles préfixées par VITE_).

# URL de votre projet Supabase (ex: https://satvespjethrqgiwsfov.supabase.com)
VITE_SUPABASE_URL=""

# Clé API publique (Anon Key) ou clé de rôle de service (Service Role Key)
VITE_SUPABASE_PUBLISHABLE_KEY=""

# PAIEMENT PRO CONFIGURATION:
# ID Marchand Paiement Pro pour le traitement sécurisé des paiements (ex: 123456)
VITE_PAIEMENT_PRO_MERCHANT_ID=""

# Secret partagé utilisé pour valider que les callbacks webhook viennent bien de Paiement Pro
# Exemple : PAYMENT_WEBHOOK_SECRET=0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d
PAYMENT_WEBHOOK_SECRET=""

# EMAILS TRANSACTIONNELS (Resend) :

# Clé API Resend (https://resend.com/api-keys). Si vide, les emails sont simplement
# loggués en console (mode mock), aucune route métier n'est bloquée.
RESEND_API_KEY=""

# Adresse/nom d'expéditeur utilisé pour tous les emails envoyés par l'application
# (doit correspondre à un domaine vérifié sur Resend en production).
RESEND_FROM_EMAIL="ClicBillet <no-reply@clicbillet.ci>"

# Adresse email recevant les notifications admin (nouvel organisateur, demande de retrait).
ADMIN_NOTIFICATION_EMAIL="admin@clicbillet.ci"

# Secret partagé utilisé pour valider que les appels vers /api/webhooks/supabase/new-user
# viennent bien du Database Webhook configuré dans le dashboard Supabase (cf. supabase_setup.sql, section 9).
SUPABASE_WEBHOOK_SECRET=""
